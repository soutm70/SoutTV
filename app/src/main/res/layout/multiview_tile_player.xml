<?xml version="1.0" encoding="utf-8"?>
<!-- Multiview tile video surface. Exists only to set surface_type, which
     PlayerView reads at constructor time and cannot change later. TextureView
     tiles composite through the single app window layer instead of N
     punch-through SurfaceViews, which overflow the TV compositor's overlay
     plane budget and read as stutter/tearing in larger grids. The fullscreen
     player (PersistentExoWindow) stays on SurfaceView. -->
<androidx.media3.ui.PlayerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="texture_view" />
