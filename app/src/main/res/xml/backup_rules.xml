<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude credential-bearing files from legacy (API < 31) full backup.
         For API 31+ the data_extraction_rules.xml exclusions apply instead. -->
    <exclude domain="database" path="aerio.db"/>
    <exclude domain="database" path="aerio.db-shm"/>
    <exclude domain="database" path="aerio.db-wal"/>
    <exclude domain="file" path="datastore/aerio_prefs.preferences_pb"/>
    <exclude domain="file" path="aerio_debug_logs.txt"/>
</full-backup-content>
