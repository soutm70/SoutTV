<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude the credential-bearing Room DB and DataStore so IPTV server
             keys and OAuth tokens are never captured in Google cloud backup or
             device-to-device transfer. -->
        <exclude domain="database" path="aerio.db"/>
        <exclude domain="database" path="aerio.db-shm"/>
        <exclude domain="database" path="aerio.db-wal"/>
        <exclude domain="file" path="datastore/aerio_prefs.preferences_pb"/>
        <exclude domain="file" path="aerio_debug_logs.txt"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="aerio.db"/>
        <exclude domain="database" path="aerio.db-shm"/>
        <exclude domain="database" path="aerio.db-wal"/>
        <exclude domain="file" path="datastore/aerio_prefs.preferences_pb"/>
        <exclude domain="file" path="aerio_debug_logs.txt"/>
    </device-transfer>
</data-extraction-rules>
